# Copie para .env e preencha (nunca commite o .env).
# cp .env.example .env

SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Opcional — sessão partilhada entre instâncias (ex.: produção com vários pods)
# REDIS_URL=redis://127.0.0.1:6379

# Opcional — erros e performance no Sentry (https://sentry.io)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.05

# Opcional — nível de log pino: trace, debug, info, warn, error, fatal, silent
# LOG_LEVEL=info

# Opcional:
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# PORT=3000
